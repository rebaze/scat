<!-- Glossary Modal -->
<div class="glossary-overlay" id="glossary-overlay" onclick="if(event.target===this)toggleGlossary()">
  <div class="glossary-panel" role="dialog" aria-label="Glossary">
    <h3>Glossary <button class="glossary-close" onclick="toggleGlossary()" aria-label="Close glossary">&times;</button></h3>
    <div class="glossary-group">
      <h4>General</h4>
      <dl>
        <dt>SBOM</dt>
        <dd>Software Bill of Materials — a complete inventory of all third-party libraries and packages found in the project.</dd>
        <dt>Risk Level</dt>
        <dd>An overall security risk rating computed from vulnerability severity counts. Critical or High vulnerabilities push the rating up.</dd>
        <dt>Ecosystem</dt>
        <dd>The package manager or platform a component belongs to (e.g., npm, Maven, PyPI, Go modules).</dd>
        <dt>Freshness</dt>
        <dd>How current the component version is relative to the latest release. Coming in a future version.</dd>
      </dl>
    </div>
    <div class="glossary-group">
      <h4>Vulnerabilities</h4>
      <dl>
        <dt>CVE</dt>
        <dd>Common Vulnerabilities and Exposures — a unique identifier assigned to a publicly disclosed security flaw.</dd>
        <dt>CISA KEV</dt>
        <dd>Known Exploited Vulnerabilities — a curated CISA list of vulnerabilities confirmed to be actively exploited in the wild.</dd>
        <dt>EPSS</dt>
        <dd>Exploit Prediction Scoring System — estimates the probability (0–100%) that a vulnerability will be exploited within 30 days.</dd>
        <dt>CVSS</dt>
        <dd>Common Vulnerability Scoring System — a standardized score (0–10) rating the technical severity of a vulnerability.</dd>
        <dt>Fix Status</dt>
        <dd>How many vulnerabilities have a patched version available. "Fixed" means an upgrade path exists in the ecosystem.</dd>
      </dl>
    </div>
    <div class="glossary-group">
      <h4>Severity Levels</h4>
      <dl>
        <dt>Critical (9.0–10.0)</dt>
        <dd>Easily exploitable flaws that can lead to full system compromise, often with no user interaction required.</dd>
        <dt>High (7.0–8.9)</dt>
        <dd>Serious vulnerabilities that can compromise confidentiality, integrity, or availability with limited complexity.</dd>
        <dt>Medium (4.0–6.9)</dt>
        <dd>Moderate-impact vulnerabilities that typically require specific conditions or user interaction to exploit.</dd>
        <dt>Low (0.1–3.9)</dt>
        <dd>Minor issues with limited impact, usually requiring local access or unlikely attack scenarios.</dd>
      </dl>
    </div>
    <div class="glossary-group">
      <h4>License Statuses</h4>
      <dl>
        <dt>Allowed</dt>
        <dd>The component's license is approved for use in your project according to the configured license policy.</dd>
        <dt>Denied</dt>
        <dd>The component's license is prohibited by the configured policy and should be replaced or removed.</dd>
        <dt>Unlicensed</dt>
        <dd>No license information was found for this component, which may pose legal risks for redistribution.</dd>
        <dt>Unknown</dt>
        <dd>The license was detected but could not be classified against the configured policy.</dd>
      </dl>
    </div>
  </div>
</div>

<script>
function toggleGlossary() {
  document.getElementById('glossary-overlay').classList.toggle('visible');
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var overlay = document.getElementById('glossary-overlay');
    if (overlay.classList.contains('visible')) {
      overlay.classList.remove('visible');
    }
  }
});
</script>

<script>
function toggleTheme() {
  var current = document.documentElement.getAttribute('data-theme');
  var isDark = current === 'dark' ||
    (!current && window.matchMedia('(prefers-color-scheme: dark)').matches);
  var next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('scat-theme', next);
}
</script>
</div>
</body>
</html>
